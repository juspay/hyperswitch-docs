# Hyperswitch Node.js Example - Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# REQUIRED: Hyperswitch API Credentials
# ==========================================
# Get these from your Hyperswitch Dashboard:
# https://app.hyperswitch.io/dashboard/settings/api-keys

# Your secret API key (starts with snd_ for sandbox, pnd_ for production)
HYPERSWITCH_SECRET_KEY=snd_your_secret_key_here

# Your publishable API key (starts with pk_snd_ for sandbox)
HYPERSWITCH_PUBLISHABLE_KEY=pk_snd_your_publishable_key_here

# ==========================================
# OPTIONAL: API Configuration
# ==========================================
# Hyperswitch API endpoint
# Use sandbox for testing: https://sandbox.hyperswitch.io
# Use production for live: https://api.hyperswitch.io
HYPERSWITCH_API_URL=https://sandbox.hyperswitch.io

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# ==========================================
# OPTIONAL: Webhook Configuration
# ==========================================
# Webhook signing secret for verifying webhooks
# HYPERSWITCH_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Your publicly accessible webhook endpoint
# WEBHOOK_URL=https://yourdomain.com/webhooks/hyperswitch

# ==========================================
# OPTIONAL: Database Configuration (if extending example)
# ==========================================
# Uncomment if you want to add order persistence
# DATABASE_URL=postgresql://user:password@localhost:5432/hyperswitch_example

# ==========================================
# OPTIONAL: Redis Configuration (if adding caching)
# ==========================================
# REDIS_URL=redis://localhost:6379

# ==========================================
# SECURITY WARNING
# ==========================================
# Never commit the .env file with real credentials to version control!
# This file (.env.example) is safe to commit as a template.